              "label": "SLA Matrix",
              "shape": "table",
              "fill": "#ffffff",
              "stroke": "#46515f",
              "text": "#172033",
              "fontSize": 12,
              "textAlign": "center",
              "tableRows": 2,
              "tableColumns": 2,
              "tableCells": ["Channel", "SLA", "VIP", "2h"],
              "width": 220,
              "height": 110
            }
          },
          {
            "id": "roundtrip-hidden-note",
            "type": "diagram",
            "hidden": true,
            "position": { "x": 650, "y": 280 },
            "data": {
              "label": "Hidden audit note",
              "shape": "note",
              "fill": "#f4f4f5",
              "stroke": "#71717a",
              "text": "#27272a",
              "fontSize": 12,
              "textAlign": "left",
              "width": 160,
              "height": 88
            }
          }
