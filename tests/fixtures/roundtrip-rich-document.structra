              "label": "Order",
              "shape": "erEntity",
              "fill": "#fff8e6",
              "stroke": "#a15c00",
              "text": "#2f2410",
              "fontSize": 13,
              "textAlign": "center",
              "erFields": [
                { "name": "order_id", "type": "uuid", "key": "PK" },
                { "name": "customer_id", "type": "uuid", "key": "FK" },
                { "name": "status", "type": "varchar" }
