{
  "name": "structra",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "test": "pnpm test:unit",
    "test:unit": "node scripts/qa/unit-tests.mjs",
    "test:e2e": "pnpm qa:smoke",
    "qa": "pnpm test && pnpm qa:smoke",
    "qa:perf": "node scripts/qa/performance-baseline.mjs && bash scripts/qa/interactive-performance.sh",
    "qa:smoke": "bash scripts/qa/playwright-smoke.sh",
    "qa:desktop": "bash scripts/qa/tauri-desktop-smoke.sh",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:dmg": "tauri build --bundles dmg"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@xyflow/react": "^12.9.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
